enum PlsContractType {
  RESTRICTED_SINGLE_VENTURE_MUDARABAH
}

enum PlsReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED_WITH_CONDITIONS
  APPROVED
  REJECTED
}

enum DistributionApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum LossAllocationRule {
  RABB_AL_MAL_BEARS_LOSS_UNLESS_MUDARIB_FAULT
}

enum ProfitCalculationBasis {
  REALIZED_PROFIT_LESS_APPROVED_DEDUCTIBLE_COSTS
}

model PlsContract {
  id                             BigInt                       @id @default(autoincrement())
  contractId                     String                       @unique @db.VarChar(100)
  contractType                   PlsContractType
  procurementReferenceId         String                       @db.VarChar(100)

  ventureDescription             String                       @db.Text
  permittedUseOfFunds            String                       @db.Text

  rabbAlMalPartyId               String                       @db.VarChar(100)
  mudaribPartyId                 String                       @db.VarChar(100)

  capitalAmount                  Decimal                      @db.Decimal(18, 2)
  currency                       String                       @db.VarChar(10)

  profitSharingRatioRabbAlMal    Decimal                      @db.Decimal(5, 4)
  profitSharingRatioMudarib      Decimal                      @db.Decimal(5, 4)

  approvedProfitDefinition       String                       @db.Text
  deductibleCostPolicyVersion    String                       @db.VarChar(50)

  restrictions                   Json
  comminglingFlag                Boolean                      @default(false)

  profitCalculationBasis         ProfitCalculationBasis
  lossAllocationRule             LossAllocationRule

  distributionPeriodStart        DateTime                     @db.Date
  distributionPeriodEnd          DateTime                     @db.Date

  evidenceBundleId               String?                      @db.VarChar(100)
  distributionApprovalStatus     DistributionApprovalStatus
  exceptionFlag                  Boolean                      @default(false)

  securityOrCollateralDetails    String?                      @db.Text

  reviewer                       String?                      @db.VarChar(150)
  reviewStatus                   PlsReviewStatus
  reviewDate                     DateTime?                    @db.Date
  shariahPronouncementReference  String?                      @db.VarChar(100)

  templateVersion                String                       @db.VarChar(50)
  templateHash                   String                       @db.VarChar(255)

  createdAt                      DateTime                     @default(now())
  updatedAt                      DateTime                     @updatedAt

  @@map("pls_contracts")
  @@index([procurementReferenceId], map: "idx_pls_contracts_procurement_reference_id")
  @@index([rabbAlMalPartyId], map: "idx_pls_contracts_rabb_al_mal_party_id")
  @@index([mudaribPartyId], map: "idx_pls_contracts_mudarib_party_id")
  @@index([reviewStatus], map: "idx_pls_contracts_review_status")
}